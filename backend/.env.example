# Azure ポータル + Foundry ポータルで取得した値を貼り付ける
# (詳細は docs/SETUP_AZURE.md セクション 8-4)

# Azure AI Document Intelligence (Azureポータル → mahted-di → キーとエンドポイント)
DOCUMENT_INTELLIGENCE_ENDPOINT=https://<your-di-resource>.cognitiveservices.azure.com/
DOCUMENT_INTELLIGENCE_KEY=

# Microsoft Foundry の Azure OpenAI 互換エンドポイント
# Foundry ポータル → プロジェクトの概要 → エンドポイント、または
# Azureポータル → mahted-foundry → キーとエンドポイント (*.openai.azure.com 形式を選ぶ)
AZURE_OPENAI_ENDPOINT=https://<your-foundry>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_GPT4O_DEPLOYMENT=gpt-4o
# 強劣化画像で呼び出しがハングしないよう timeout(秒)/リトライ上限を設定
AZURE_OPENAI_TIMEOUT=60
AZURE_OPENAI_MAX_RETRIES=2

# Azure AI Foundry Agent Service (Day 5〜6 で利用する場合のみ)
# Foundry ポータル → プロジェクトの概要 → プロジェクトエンドポイント
AI_FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry>.services.ai.azure.com/api/projects/proj-default
AI_FOUNDRY_MODEL_DEPLOYMENT=gpt-4o

# Storage (任意 — PDFを永続化したい場合のみ)
AZURE_STORAGE_CONNECTION_STRING=

# CORS (ローカル開発はそのままで OK)
CORS_ORIGINS=http://localhost:3000
MAX_UPLOAD_BYTES=15728640
